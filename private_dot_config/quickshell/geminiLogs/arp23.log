       94
       95         if (action === "dashboard") vis.dashboard = !vis.dashboard;
       96         else if (action === "launcher") vis.launcher = !vis.launcher;
       97         else if (action === "session") vis.session = !vis.session;
       98         else if (action === "sidebar") vis.sidebar = !vis.sidebar;
       99         else if (action === "utilities") vis.utilities = !vis.utilities;
